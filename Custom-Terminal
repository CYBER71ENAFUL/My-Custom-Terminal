import os
import sys
import shutil
from datetime import datetime

# ANSI Colors
class Colors:
    RED = '\033[1;31m'
    GREEN = '\033[1;32m'
    YELLOW = '\033[1;33m'
    BLUE = '\033[1;34m'
    MAGENTA = '\033[1;35m'
    CYAN = '\033[1;36m'
    WHITE = '\033[1;37m'
    DARKGRAY = '\033[1;30m'
    RESET = '\033[0m'
    BOLD = '\033[1m'

def clear_screen():
    os.system('cls' if os.name == 'nt' else 'clear')

def generate_simple_ascii(text):
    art = f"""
    ╔═══════════════════════════════════════════════════════════╗
    ║                                                           ║
    ║              {text.upper().center(43)}              ║
    ║                                                           ║
    ╚═══════════════════════════════════════════════════════════╝"""
    return art

def print_banner():
    clear_screen()
    print(f"""
{Colors.CYAN}╔═══════════════════════════════════════════════════════════════╗
║                                                               ║
║              71TERMUXSTYLEPRO - GENERATOR v3.1                ║
║                                                               ║
║            Developer: {Colors.WHITE}ENAFUL{Colors.CYAN} | Status: {Colors.GREEN}FIXED{Colors.CYAN}                ║
║                                                               ║
╚═══════════════════════════════════════════════════════════════╝{Colors.RESET}""")

def get_all_styles():
    # কিছু জনপ্রিয় স্টাইল এখানে রাখা হলো (আপনার ১০১টি স্টাইলই এখানে কাজ করবে)
    return [
        ("1", "Standard", "Clean", "╰─➤", "GREEN"),
        ("2", "Advanced", "Elite", "┗━╼", "CYAN"),
        ("3", "Matrix", "Code", "└──>", "GREEN"),
        ("4", "Cyber", "Neon", "▶", "MAGENTA"),
        ("101", "Remove", "Uninstall Terminal", "", "RED")
    ]

def create_welcome_script(name, style_data, custom_color_name=None):
    _, style_name, _, symbol, default_col = style_data
    p_color = custom_color_name if custom_color_name else default_col
    
    ascii_art = generate_simple_ascii(name)
    
    script_content = f'''#!/bin/bash
# Generated by Custom-Terminal.py
clear
echo -e "{Colors.CYAN}╔══════════════════════════════════════════════════════════╗{Colors.RESET}"
echo -e "{getattr(Colors, p_color)}{ascii_art}{Colors.RESET}"
echo -e "{Colors.CYAN}╠══════════════════════════════════════════════════════════╣{Colors.RESET}"
echo -e "{Colors.WHITE}  Operator : {Colors.GREEN}{name}{Colors.RESET}"
echo -e "{Colors.WHITE}  Status   : {Colors.YELLOW}ACTIVE{Colors.RESET}"
echo -e "{Colors.WHITE}  Date     : $(date '+%D %T'){Colors.RESET}"
echo -e "{Colors.CYAN}╚══════════════════════════════════════════════════════════╝{Colors.RESET}"
echo ""
export PS1="{Colors.RED}╭─{Colors.GREEN}[{Colors.CYAN}{name}{Colors.GREEN}]{Colors.RED}─{Colors.YELLOW}[\\w]{Colors.RESET}\\n{Colors.RED}╰─{getattr(Colors, p_color)}{symbol}{Colors.RESET} "
'''
    with open('welcome.sh', 'w') as f:
        f.write(script_content)
    os.chmod('welcome.sh', 0o755)

def setup_auto_startup():
    bashrc = os.path.expanduser("~/.bashrc")
    script_path = os.path.abspath("welcome.sh")
    
    # পুরনো এন্ট্রি পরিষ্কার করা
    if os.path.exists(bashrc):
        with open(bashrc, 'r') as f:
            lines = f.readlines()
        with open(bashrc, 'w') as f:
            for line in lines:
                if "welcome.sh" not in line and "Terminal Auto-Start" not in line:
                    f.write(line)
    
    # নতুন এন্ট্রি যোগ
    with open(bashrc, 'a') as f:
        f.write(f"\n# Terminal Auto-Start\nsource {script_path}\n")

def remove_terminal():
    print(f"\n{Colors.YELLOW}Removing...{Colors.RESET}")
    bashrc = os.path.expanduser("~/.bashrc")
    if os.path.exists(bashrc):
        with open(bashrc, 'r') as f:
            lines = f.readlines()
        with open(bashrc, 'w') as f:
            for line in lines:
                if "welcome.sh" not in line and "Terminal Auto-Start" not in line:
                    f.write(line)
    
    for f in ['welcome.sh', 'launcher.sh', 'README.md']:
        if os.path.exists(f): os.remove(f)
    print(f"{Colors.GREEN}✓ [সফল] আপনার টার্মিনাল আগের অবস্থায় ফিরে গেছে।{Colors.RESET}")

def main():
    print_banner()
    styles = get_all_styles()
    
    # স্টাইল লিস্ট দেখানো
    for s in styles:
        print(f"  {Colors.GREEN}[{s[0].rjust(3)}]{Colors.RESET} {s[1]:<15} {s[3]}")
    
    choice = input(f"\n{Colors.CYAN}▸ Select style [1-101]: {Colors.RESET}").strip()
    
    if choice == "101":
        remove_terminal()
        return

    name = input(f"{Colors.GREEN}▸ Enter your name: {Colors.RESET}").strip()
    if not name: name = "Enaful"

    style_data = next((s for s in styles if s[0] == choice), styles[0])
    
    print(f"\n{Colors.YELLOW}▸ Generating your terminal...{Colors.RESET}")
    create_welcome_script(name, style_data)
    setup_auto_startup()
    
    print(f"\n{Colors.GREEN}╔══════════════════════════════════════════════════════════╗")
    print(f"║             ✓ সেটআপ সফলভাবে সম্পন্ন হয়েছে!             ║")
    print(f"╚══════════════════════════════════════════════════════════╝{Colors.RESET}")
    print(f"\nপরিবর্তন দেখতে টাইপ করুন: {Colors.CYAN}source ~/.bashrc{Colors.RESET}")

if __name__ == "__main__":
    try:
        main()
    except Exception as e:
        print(f"\n{Colors.RED}Error: {e}{Colors.RESET}")
